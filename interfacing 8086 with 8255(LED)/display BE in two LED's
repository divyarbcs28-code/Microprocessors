		OUTPUT 2500AD
.ORG 2000H
DATA SEGMENT
CHAR_B DB 7CH
CHAR_E DB 79H
DATA ENDS
CODE SEGMENT
    ASSUME CS:CODE, DS:DATA
START:
    MOV AX, DATA
    MOV DS, AX
    MOV AL, 80H
    MOV DX, 0FFE6H
    OUT DX, AL
REPEAT:
    MOV AL, CHAR_B
    MOV DX, 0FFE0H
    OUT DX, AL  
    MOV AL, 01H
    MOV DX, 0FFE2H
    OUT DX, AL
    CALL DELAY
    MOV AL, CHAR_E
    MOV DX, 0FFE0H
    OUT DX, AL    
    MOV AL, 02H
    MOV DX, 0FFE2H
    OUT DX, AL
    CALL DELAY
    JMP REPEAT
DELAY:
    MOV CX, 0300H
L1: LOOP L1
    RET
CODE ENDS
END 

