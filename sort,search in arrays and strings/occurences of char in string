		OUTPUT 2500AD
.ORG 2000H
DATA SEGMENT
STRING1 DB "HELLO"
STRING2 DB 'L'
RESULT DB 00H
COUNT DB 05H
DATA ENDS
CODE SEGMENT
	ASSUME CS:CODE,DS:DATA,ES:DATA
	MOV AX,DATA
	MOV DS,AX
	MOV ES,AX
	MOV CL,COUNT
	LEA DI,STRING1
	MOV AL,STRING2
	CLD
L2:     SCASB
	JNZ L1
	MOV RESULT,01H
	JMP L3
L1:     MOV RESULT,00H
	DEC CL
	JNZ L2
L3:     HLT
CODE ENDS
END

